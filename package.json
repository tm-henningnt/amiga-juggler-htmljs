{
  "name": "amiga-juggler-htmljs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:calibration": "tsc -p tsconfig.calibration.json",
    "build:single": "tsc -p tsconfig.json && tsc -p tsconfig.worker.json && node scripts/build-single.mjs",
    "calibrate:classic": "npm run build:calibration && node scripts/classic-calibration.mjs",
    "test": "tsc -p tsconfig.test.json && node dist-test/tests.js"
  }
}
