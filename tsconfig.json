{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "outFile": "dist/juggler.js",
    "rootDir": "src",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true
  },
  "files": [
    "src/types.ts",
    "src/math.ts",
    "src/experience.ts",
    "src/profiles.ts",
    "src/original-data.ts",
    "src/reference-frames.ts",
    "src/scenes.ts",
    "src/parser.ts",
    "src/motion-data.ts",
    "src/motion.ts",
    "src/ham.ts",
    "src/display.ts",
    "src/renderer.ts",
    "src/transforms.ts",
    "src/preview.ts",
    "src/viewport.ts",
    "src/live-playback.ts",
    "src/animation.ts",
    "src/app.ts"
  ]
}
